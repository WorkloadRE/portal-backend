# Application Configuration
# Required setting for application to function properly
APP_SETTINGS_PRESET=defaults

# Environment setting that removes configuration checks required in hosted environments
APP_ENVIRONMENT=localhost
PORT=8080

# Repliers API Configuration
# Configure your Repliers API settings for real estate data access
REPLIERS_BASE_URL=https://api.repliers.io
REPLIERS_API_LIMIT=1
REPLIERS_API_INTERVAL_MS=1000

# Repliers API Key
# Get your API key by creating a free account at https://login.repliers.com/
REPLIERS_API_KEY=<repliers_api_key>

# Board scope — Houston MSA via HAR is board 147
APP_DEFAULTS_BOARDIDS=147
APP_LOCATIONS_BOARDID=147

# Mapbox Configuration
# Mapbox API key is required for location and mapping features
# Create a free account at https://www.mapbox.com/ to obtain your API key
MAPBOX_ACCESS_TOKEN=<mapbox_api_key>

# Google Maps (optional — Street View + Places autosuggest fallback)
GOOGLE_MAPS_API_KEY=<google_maps_api_key>

# JWT Configuration
# Generate local JWT keys by running: npm run jwt:generate
JWT_PUBLIC_KEY=keys/public.pem
JWT_PRIVATE_KEY=keys/private.pem
JWT_EXPIRE=24h

# Postgres (Supabase in prod — use transaction pooler host/port 6543)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgrespw
DB_NAME=repliers
DB_USE_SSL=false

# Follow Up Boss — LEGACY. Bruno Fine Properties runs BOSS_ENABLED=false
# because ActiveCampaign is the primary CRM. Leave false in prod.
BOSS_ENABLED=false
BOSS_BASEURL=https://api.followupboss.com/v1
BOSS_USERNAME=
BOSS_PASSWORD=
BOSS_SYSTEM=
BOSS_SYSTEM_KEY=
BOSS_WEBHOOK_ENABLED=false

# ActiveCampaign — PRIMARY CRM for Bruno Fine Properties.
# Shared instance with SpringHomeSearch; Source-BrunoFineProperties-IDX
# tag distinguishes BFP leads from SHS leads.
ACTIVECAMPAIGN_ENABLED=true
ACTIVECAMPAIGN_API_URL=<activecampaign_base_url>
ACTIVECAMPAIGN_API_KEY=<activecampaign_api_key>
ACTIVECAMPAIGN_LIST_ID=<activecampaign_list_id>
ACTIVECAMPAIGN_STATE_CODE=TX

# CORS — comma-separated origins allowed to call the API
APP_CORS_DOMAIN=http://localhost:3000,https://search.brunofineproperties.com,https://brunofineproperties.com
